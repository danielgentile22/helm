<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.helm.hud</string>
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/node</string>
        <string>/Users/user/Projects/helm/node_modules/.bin/next</string>
        <string>start</string>
        <string>-p</string>
        <string>3107</string>
        <string>-H</string>
        <string>127.0.0.1</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/user/Projects/helm</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/user/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>NODE_ENV</key>
        <string>production</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>
    <key>StandardOutPath</key>
    <string>/Users/user/Projects/helm/logs/hud.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/user/Projects/helm/logs/hud.log</string>
</dict>
</plist>
