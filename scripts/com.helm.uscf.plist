        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>/Users/user/Projects/helm/logs/uscf.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/user/Projects/helm/logs/uscf.log</string>
</dict>
</plist>
